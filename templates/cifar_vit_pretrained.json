{
  "seed": 0,
  "pipeline_mode": "phased",
  "experiment_name": "cifar_vit_pretrained",
  "generated_files_path": "./generated",
  "data_provider_name": "CIFAR10_DataProvider",
  "platform_constraints": {
    "cores": [
      {
        "max_axons": 3072,
        "max_neurons": 768,
        "count": 69,
        "has_bias": true
      },
      {
        "max_axons": 768,
        "max_neurons": 3072,
        "count": 69,
        "has_bias": true
      }
    ],
    "max_axons": 3072,
    "max_neurons": 3072,
    "target_tq": 32,
    "simulation_steps": 32,
    "weight_bits": 8,
    "has_bias": true,
    "allow_coalescing": false
  },
  "deployment_parameters": {
    "lr": 0.0001,
    "tuning_budget_scale": 1,
    "degradation_tolerance": 0.1,
