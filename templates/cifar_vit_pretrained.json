    "training_recipe": {
      "optimizer": "adamw",
      "weight_decay": 0.05,
      "betas": [0.9, 0.999],
      "scheduler": "cosine",
      "warmup_ratio": 0.1,
      "grad_clip_norm": 1.0,
      "layer_wise_lr_decay": 0.75,
